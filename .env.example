# ScaleSolo environment variables
# Copy this file to .env (root) for local dev, and set the same vars in Vercel for staging / prod.

# ── Supabase (the ScaleSolo project, NOT VTM) ────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Frontend equivalents (Vite needs the VITE_ prefix to expose to the client)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=

# ── App config ───────────────────────────────────────────────────────────────
SCALESOLO_DOMAIN=https://scalesolo.app
FRONTEND_URL=https://scalesolo.app
ALLOWED_ORIGINS=https://scalesolo.app,https://staging.scalesolo.app,http://localhost:5180

# ── AI providers ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=
HEYGEN_API_KEY=
KIE_API_KEY=
NANOBANANA_API_KEY=
OPENAI_API_KEY=          # for text-embedding-3-small in M3 AI CEO memory

# ── Email ────────────────────────────────────────────────────────────────────
POSTMARK_API_KEY=        # native sending (M4)
# MailerLite is per-tenant (stored in email_config table) — no global key

# ── Social publishing ────────────────────────────────────────────────────────
UPLOADPOST_API_KEY=

# ── Stripe (the ScaleSolo Stripe account) ────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_SOLO_STARTER=
STRIPE_PRICE_SOLO_STARTER_ANNUAL=
STRIPE_PRICE_SOLO_PRO=
STRIPE_PRICE_SOLO_PRO_ANNUAL=
STRIPE_PRICE_SOLO_STUDIO=
STRIPE_PRICE_SOLO_STUDIO_ANNUAL=
STRIPE_PRICE_FOUNDING=

# ── Cron protection ──────────────────────────────────────────────────────────
CRON_SECRET=

# ── HTML→image (thumbnails) ──────────────────────────────────────────────────
HCTI_USER_ID=
HCTI_API_KEY=

# ── Observability (Sentry) ───────────────────────────────────────────────────
# Server-side DSN. Set in Vercel env (production + preview) so unhandled
# API errors + credit-consume failures surface in Sentry.
SENTRY_DSN=
# Client-side DSN — exposed in the browser bundle (intentional, all
# Sentry DSNs are public-by-design). Use the SAME DSN as SENTRY_DSN.
VITE_SENTRY_DSN=
# Optional release tag. Vercel auto-injects VERCEL_GIT_COMMIT_SHA which
# the SDK reads, but you can override here for staging vs prod.
VITE_SENTRY_RELEASE=

# ── At-rest secret encryption ────────────────────────────────────────────────
# Used by api/_lib/crypto.js (AES-256-GCM) for BYOK ElevenLabs keys.
# Generate: openssl rand -hex 32
ELEVENLABS_KEY_SECRET=
