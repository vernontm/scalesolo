{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ],
  "crons": [
    { "path": "/api/cron/credit-monthly-reset", "schedule": "0 6 * * *" },
    { "path": "/api/admin/affiliates-close",    "schedule": "0 7 * * *" },
    { "path": "/api/cron/sweep-stale-renders",  "schedule": "*/15 * * * *" }
  ],
  "functions": {
    "api/videos/combine.js": {
      "includeFiles": "node_modules/@ffmpeg/core/**",
      "maxDuration": 300
    },
    "api/videos/polish.js": {
      "includeFiles": "{node_modules/@ffmpeg-installer/**,api/_fonts/**}",
      "maxDuration": 300
    },
    "api/social/upload-post.js": {
      "maxDuration": 60
    }
  }
}
